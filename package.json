{
  "name": "vr-md-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:http": "VITE_USE_HTTP=1 vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "XDG_CONFIG_HOME=.wrangler/config WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --ip 0.0.0.0 --port 8787 --inspector-port 0 --local-protocol=http",
    "worker:dev:https": "XDG_CONFIG_HOME=.wrangler/config WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --ip 0.0.0.0 --port 8787 --inspector-port 0 --local-protocol=https",
    "worker:deploy": "XDG_CONFIG_HOME=.wrangler/config WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.3",
    "wrangler": "^3.114.17"
  },
  "dependencies": {
    "three": "^0.169.0"
  }
}
